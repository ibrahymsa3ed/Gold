<?xml version="1.0" encoding="utf-8"?>
<!--
  InstaGold Android home-screen widget layout (minimal, dark-only).
  Mirrors the iOS widget structure: brand header + time pill, three price
  rows separated by hairlines. Colors hardcoded inline because RemoteViews
  cannot resolve theme attributes (?attr/...) at render time.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/instagold_widget_bg">

    <!-- Header: iG mark + InstaGold wordmark on the leading edge,
         updated-time pill on the trailing edge. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="8dp">

        <ImageView
            android:id="@+id/widget_brand_mark"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ig_logo_mark"
            android:scaleType="fitCenter"
            android:contentDescription="@null"
            android:importantForAccessibility="no"
            android:layout_marginEnd="6dp"
            android:layout_marginRight="6dp" />

        <TextView
            android:id="@+id/widget_brand"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="InstaGold"
            android:textColor="#8CFFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#8CFFFFFF"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:paddingStart="7dp"
            android:paddingEnd="7dp"
            android:paddingLeft="7dp"
            android:paddingRight="7dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:background="@drawable/instagold_widget_time_pill" />
    </LinearLayout>

    <!-- 21K row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <TextView
            android:id="@+id/widget_label_21"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#8CFFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_value_21"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#D4AF37"
            android:textSize="17sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:singleLine="true"
            android:ellipsize="end" />
    </LinearLayout>

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#14FFFFFF"
        android:contentDescription="@null"
        android:importantForAccessibility="no" />

    <!-- 24K row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <TextView
            android:id="@+id/widget_label_24"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#8CFFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_value_24"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#D4AF37"
            android:textSize="17sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:singleLine="true"
            android:ellipsize="end" />
    </LinearLayout>

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#14FFFFFF"
        android:contentDescription="@null"
        android:importantForAccessibility="no" />

    <!-- Ounce row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <TextView
            android:id="@+id/widget_label_ounce"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#8CFFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_value_ounce"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#D4AF37"
            android:textSize="17sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:singleLine="true"
            android:ellipsize="end" />
    </LinearLayout>
</LinearLayout>
